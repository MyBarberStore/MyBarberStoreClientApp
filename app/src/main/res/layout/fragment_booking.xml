<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/login_bg_dark">

    <LinearLayout
        android:id="@+id/llProgressBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="18dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvStep1"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="@drawable/bg_circle_step_active"
            android:gravity="center"
            android:text="1"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <View android:layout_width="30dp" android:layout_height="2dp" android:background="#E0E0E0" android:layout_marginHorizontal="8dp"/>

        <TextView
            android:id="@+id/tvStep2"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="@drawable/bg_circle_step_inactive"
            android:gravity="center"
            android:text="2"
            android:textColor="#7F8C8D" />

        <View android:layout_width="30dp" android:layout_height="2dp" android:background="#E0E0E0" android:layout_marginHorizontal="8dp"/>

        <TextView
            android:id="@+id/tvStep3"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="@drawable/bg_circle_step_inactive"
            android:gravity="center"
            android:text="3"
            android:textColor="#7F8C8D" />

        <View android:layout_width="30dp" android:layout_height="2dp" android:background="#E0E0E0" android:layout_marginHorizontal="8dp"/>

        <TextView
            android:id="@+id/tvStep4"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="@drawable/bg_circle_step_inactive"
            android:gravity="center"
            android:text="4"
            android:textColor="#7F8C8D" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/bookingStepContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/bg_input_rounded"
        android:layout_marginTop="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llProgressBar" />

</androidx.constraintlayout.widget.ConstraintLayout>